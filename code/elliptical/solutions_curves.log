def eval_quartic(quartic_poly: Polynomial_rational_flint, pt: Rational) -> bool:
    """ Compare ceofficient and eval method of evaluating quartic at a point.
    """
    c0, c1, c2, c3, c4 = quartic_poly.list()
    nx = pt.numerator()
    nz = pt.denominator()
    ve = quartic_poly(pt)
    vc = (c4 * nx**4 + c3 * nx**3 * nz + c2 * nx**2 * nz**2 + c1 * nx * nz**3 + c0 * nz**4)
    va = (c4 * pt**4 + c3 * pt**3 + c2 * pt**2 + c1 * pt + c0)
    print(ve, abs(ve).is_square())
    print(vc, abs(vc).is_square())
    print(va, abs(va).is_square())
    repeat('quartic_poly(pt)', number=10_000, repeat=3, globals=globals())
    repeat('c4*pt**4+c3*pt**3+c2*pt**2+c1*pt+c0', number=10_000, repeat=3, globals=globals())
    return(ve == va)

