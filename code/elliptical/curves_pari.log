    """ Given m, search n over range (n_s, n_e)
    for quartics with rational point.
    Limit hyperellratpoints by h: max(n,d), (n,d), or (n,(d1,d2)
    """
    assert m%4 == 0
    assert n_s%4 == 1
    assert 1 <= n_s <= n_e
